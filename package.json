{
  "name": "ai-workflow-kit",
  "version": "2.1.0",
  "description": "Skills, agents & hooks for Claude Code, Cursor, GitHub Copilot, and Google Antigravity",
  "type": "module",
  "bin": {
    "ai-workflow-kit": "./bin/cli.js"
  },
  "scripts": {
    "start": "npx node bin/cli.js",
    "test": "vitest run evals/hooks evals/cli",
    "test:watch": "vitest evals/hooks evals/cli",
    "eval": "npx node evals/run-evals.js",
    "test:all": "vitest run evals/hooks evals/cli && npx node evals/run-evals.js",
    "release:patch": "npx node scripts/release.js patch",
    "release:minor": "npx node scripts/release.js minor",
    "release:major": "npx node scripts/release.js major",
    "release:beta": "npx node scripts/release.js beta"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "copilot",
    "ai-coding",
    "skills",
    "agents",
    "hooks",
    "workflow"
  ],
  "author": "Bezael Pérez <bezael@dominicode.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bezael/ai-workflow-kit"
  },
  "engines": {
    "node": ">=18"
  }
}
