{
  "name": "ai-workflow-kit",
  "version": "1.0.0",
  "description": "Skills, agents & hooks for Claude Code, Cursor and GitHub Copilot",
  "type": "module",
  "bin": {
    "ai-workflow-kit": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "vitest run evals/hooks evals/cli",
    "test:watch": "vitest evals/hooks evals/cli",
    "eval": "node evals/run-evals.js",
    "test:all": "vitest run evals/hooks evals/cli && node evals/run-evals.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "vitest": "^3.1.1"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "copilot",
    "ai-coding",
    "skills",
    "agents",
    "hooks",
    "workflow"
  ],
  "author": "Bezael Pérez <bezael@dominicode.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bezael/ai-workflow-kit"
  },
  "engines": {
    "node": ">=18"
  }
}
